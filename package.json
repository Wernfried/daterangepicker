{
  "name": "@wernfried/daterangepicker",
  "version": "5.3.4",
  "description": "Date range picker with time component and pre-defined ranges",
  "module": "dist/esm/daterangepicker.js",
  "exports": {
    ".": {
      "import": "./dist/esm/daterangepicker.js",
      "require": "./dist/cjs/daterangepicker.cjs"
    },
    "./css/*": "./css/*"
  },
  "browser": "dist/global/daterangepicker.min.js",
  "jsdelivr": "dist/global/daterangepicker.min.js",
  "unpkg": "dist/global/daterangepicker.min.js",
  "style": "css/daterangepicker.css",
  "source": "src/daterangepicker.js",
  "type": "module",
  "scripts": {
    "postversion": "sed -bi -e 's/daterangepicker@[[:digit:]]\\.[[:digit:]]\\+\\.[[:digit:]]\\+/daterangepicker@%npm_package_version%/' README.md",
    "build": "rollup -c",
    "postbuild": "minify css/daterangepicker.css > css/daterangepicker.min.css && minify css/daterangepicker.bulma.css > css/daterangepicker.bulma.min.css",
    "unix2dos": "unix2dos.exe -q dist/*/*js css/*.min.css",
    "prepack": "sed -n -bi '/## Options/q;p' README.md && npm run build && npm run unix2dos",
    "prepare": "jsdoc2md --EOL win32 --example-lang js src/daterangepicker.js > API_Doc.md && sed -n '/## Options$/,$p' API_Doc.md | sed -n '/name=\"Ranges\"/q;p' >> README.md && unix2dos.exe -q README.md",
    "postpack": "git commit -a -m \"Updated README.md\"",
    "test": "node --experimental-vm-modules --no-warnings ./node_modules/jest/bin/jest.js --runInBand"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {}
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wernfried/daterangepicker.git"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdoc-to-markdown": "^9.1.3",
    "minify": "^15.2.0",
    "rollup": "^4.60.0",
    "rollup-plugin-esbuild-minify": "^1.3.0"
  },
  "author": {
    "name": "Wernfried Domscheit",
    "url": "https://www.domscheit.ch"
  },
  "keywords": [
    "daterangepicker",
    "html",
    "date",
    "time",
    "datepicker",
    "timepicker",
    "rangepicker",
    "calendar"
  ],
  "files": [
    "/dist",
    "/css",
    "API_Doc.md"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wernfried/daterangepicker/issues"
  },
  "homepage": "https://github.com/wernfried/daterangepicker",
  "dependencies": {
    "luxon": "^3.7.2"
  }
}
